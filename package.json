{
  "name": "@mnee-ui/ui",
  "version": "0.0.5",
  "description": "MNEE Design System — components and documentation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mnee-xyz/mnee-ui"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/components/ui/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/components/ui/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./components/ui/mnee-ui.css"
  },
  "files": [
    "dist/",
    "components/ui/mnee-ui.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "tailwindcss": ">=3"
  },
  "scripts": {
    "build:lib": "tsup && tsc --project tsconfig.lib.json",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "figma:parse": "npx figma connect parse --dry-run",
    "figma:publish": "npx figma connect publish"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "^15.5.12",
    "react": ">=18",
    "react-dom": "^19.0.0",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@figma/code-connect": "^1.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.12",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
